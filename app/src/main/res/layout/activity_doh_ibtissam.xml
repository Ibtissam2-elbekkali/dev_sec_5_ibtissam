<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_ibtissam"
    android:padding="16dp"
    tools:context=".DohActivity_ibtissam">

    <TextView
        android:id="@+id/tvTitle_doh_ibtissam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/border_ibtissam"
        android:padding="4dp"
        android:text="Test DNS-over-HTTPS (DoH)"
        android:textColor="@color/primary_text_ibtissam"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDescription_doh_ibtissam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="DNS-over-HTTPS chiffre les requêtes DNS pour protéger contre le spoofing DNS."
        android:textColor="@color/primary_text_ibtissam"
        app:layout_constraintTop_toBottomOf="@id/tvTitle_doh_ibtissam" />

    <EditText
        android:id="@+id/etDomain_doh_ibtissam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Entrez un nom de domaine"
        android:textColor="@color/primary_text_ibtissam"
        android:textColorHint="#88FFFFFF"
        android:inputType="textUri"
        android:text="google.com"
        app:layout_constraintTop_toBottomOf="@id/tvDescription_doh_ibtissam" />

    <Button
        android:id="@+id/btnResolve_doh_ibtissam"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:text="Résoudre"
        app:layout_constraintEnd_toStartOf="@id/btnTestRequest_doh_ibtissam"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etDomain_doh_ibtissam" />

    <Button
        android:id="@+id/btnTestRequest_doh_ibtissam"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="4dp"
        android:text="Tester Requête"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnResolve_doh_ibtissam"
        app:layout_constraintTop_toBottomOf="@id/etDomain_doh_ibtissam" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnResolve_doh_ibtissam">

        <TextView
            android:id="@+id/tvResult_doh_ibtissam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Entrez un nom de domaine et appuyez sur Résoudre"
            android:textColor="@color/primary_text_ibtissam"
            android:textSize="16sp" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>