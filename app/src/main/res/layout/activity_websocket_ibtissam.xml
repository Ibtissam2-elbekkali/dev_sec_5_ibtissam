<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_ibtissam"
    android:padding="16dp"
    tools:context=".WebSocketActivity_ibtissam">

    <TextView
        android:id="@+id/tvTitle_ws_ibtissam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/border_ibtissam"
        android:padding="4dp"
        android:text="Test WebSocket"
        android:textColor="@color/primary_text_ibtissam"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDescription_ws_ibtissam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Les WebSockets permettent une communication bidirectionnelle en temps réel."
        android:textColor="@color/primary_text_ibtissam"
        app:layout_constraintTop_toBottomOf="@id/tvTitle_ws_ibtissam" />

    <TextView
        android:id="@+id/tvStatus_ws_ibtissam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Non connecté"
        android:textColor="@color/primary_text_ibtissam"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/tvDescription_ws_ibtissam"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnConnect_ws_ibtissam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connecter"
        app:layout_constraintTop_toBottomOf="@id/tvDescription_ws_ibtissam"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages_ws_ibtissam"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnConnect_ws_ibtissam"
        app:layout_constraintBottom_toTopOf="@id/etMessage_ws_ibtissam" />

    <EditText
        android:id="@+id/etMessage_ws_ibtissam"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:hint="Entrez un message"
        android:textColor="@color/primary_text_ibtissam"
        android:textColorHint="#88FFFFFF"
        android:inputType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSend_ws_ibtissam" />

    <Button
        android:id="@+id/btnSend_ws_ibtissam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Envoyer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>